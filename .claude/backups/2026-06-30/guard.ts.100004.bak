import { isKickedOff } from './engine'
import { verifyPlayerPinThrottled } from './throttle'

export type GuardResult =
  | { ok: true; community: 'hu' | 'en'; player: string }
  | { ok: false; status: number; error: string; retryAfterMs?: number }

// Shared write guard: validate PIN (throttled auth) and enforce the server-side kickoff
// lock (INV-10). `request` is needed so the PIN check shares the brute-force throttle key
// with every other PIN-checking endpoint (S1).
export async function guardWrite(
  request: Request,
  body: {
    player?: string
    pin?: string
    community?: string
    matchId?: number
  }
): Promise<GuardResult> {
  const player = String(body.player ?? '').trim()
  const pin = String(body.pin ?? '').trim()
  const community = body.community === 'en' ? 'en' : 'hu'
  const matchId = Number(body.matchId)

  if (!player || !Number.isInteger(matchId)) {
    return { ok: false, status: 400, error: 'bad-request' }
  }

  // Automated-test user (e.g. Firecrawl): skip PIN + kickoff lock so a crawler can exercise
  // writes. Off unless TEST_LOGIN_USER env names this exact player.
  if (process.env.TEST_LOGIN_USER && player === process.env.TEST_LOGIN_USER) {
    return { ok: true, community, player }
  }

  if (!/^\d{4}$/.test(pin)) {
    return { ok: false, status: 400, error: 'bad-request' }
  }

  // Kickoff lock before PIN: a locked match never consumes a throttle attempt.
  if (isKickedOff(matchId, Date.now())) {
    return { ok: false, status: 423, error: 'match-locked' }
  }

  const pinResult = await verifyPlayerPinThrottled(request, player, pin, community)
  if (!pinResult.ok) {
    return {
      ok: false,
      status: pinResult.status,
      error: pinResult.error,
      ...(pinResult.retryAfterMs ? { retryAfterMs: pinResult.retryAfterMs } : {})
    }
  }

  return { ok: true, community, player }
}
